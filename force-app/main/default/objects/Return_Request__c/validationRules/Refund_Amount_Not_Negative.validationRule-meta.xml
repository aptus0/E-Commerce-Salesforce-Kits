<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Refund_Amount_Not_Negative</fullName>
    <active>true</active>
    <description>Prevents negative refund amounts.</description>
    <errorConditionFormula>Refund_Amount__c &lt; 0</errorConditionFormula>
    <errorDisplayField>Refund_Amount__c</errorDisplayField>
    <errorMessage>Refund amount cannot be negative.</errorMessage>
</ValidationRule>
