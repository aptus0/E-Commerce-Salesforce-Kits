{
  "info": {
    "name": "CommercePulse 360 API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "Dashboard Summary",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/dashboard/summary"
      }
    },
    {
      "name": "Products",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/products"
      }
    },
    {
      "name": "Customers",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/customers"
      }
    },
    {
      "name": "Orders",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/orders"
      }
    },
    {
      "name": "Returns",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/returns"
      }
    },
    {
      "name": "Campaigns",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/campaigns"
      }
    },
    {
      "name": "Sync Logs",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/sync/logs"
      }
    },
    {
      "name": "Test Sync Connection",
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/api/sync/test"
      }
    }
  ]
}